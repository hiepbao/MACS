@using MACS.Models;
@* @model IEnumerable<MACS.Models.VehicleLog>; *@
@model dynamic;
@{
    ViewData["Title"] = "Home Page";
}
<style>
    .custom-alert {
        position: fixed;
        bottom: 20px;
        right: 20px;
        min-width: 300px;
        padding: 15px 20px;
        font-size: 14px;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        z-index: 1050;
        opacity: 0; /* Ẩn ban đầu */
        transform: translateY(20px); /* Đẩy xuống một chút */
        animation: fadeIn 0.5s forwards, fadeOut 5s forwards 4.5s; /* Fade in và fade out */
    }

    /* Màu sắc cho từng loại thông báo */
    .custom-alert.success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .custom-alert.error {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .custom-alert.info {
        background-color: #d1ecf1;
        color: #0c5460;
        border: 1px solid #bee5eb;
    }

    .custom-alert.warning {
        background-color: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }

    /* Hiệu ứng fade-in */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Hiệu ứng fade-out */
    @@keyframes fadeOut {
        from {
            opacity: 1;
            transform: translateY(0);
        }
        to {
            opacity: 0;
            transform: translateY(20px);
        }
    }

</style>

<!-- header Start -->
<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <p class="h2 text-center">Danh sách xe chờ theo dõi</p>
        <div class="col-md-6 mb-4">
            <fieldset class="form-group">
                <select class="form-select" id="basicSelect" aria-label>
                    <option value="Ra vào kho">Ra vào kho</option>
                    <option value="Kho ra vào">Kho ra vào</option>
                    <option value="Vào ra kho">Vào ra kho</option>
                </select>
            </fieldset>
        </div>
        <div class="">
            
            <button type="button" class="btn btn-primary m-2" data-bs-toggle="modal" id="qrCodeButton" data-bs-target="#qrCodeModal">
                <i class="fas fa-qrcode me-2"></i>QRCode
            </button>
        </div>
    </div>

</div>
<!-- header End -->

<!-- body Start -->
<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded h-100 p-4">
        <h6 class="mb-4">Basic Navs & Tabs</h6>
        <nav>
            <div class="nav nav-tabs" id="nav-tab" role="tablist">
                <button class="nav-link active" id="nav-home-tab" data-bs-toggle="tab"
                        data-bs-target="#nav-home" type="button" role="tab" aria-controls="nav-home"
                        aria-selected="true">
                    Xe chờ ra
                </button>
                <button class="nav-link" id="nav-profile-tab" data-bs-toggle="tab"
                        data-bs-target="#nav-profile" type="button" role="tab"
                        aria-controls="nav-profile" aria-selected="false">
                    Container chờ ra
                </button>

            </div>
        </nav>
        <div class="tab-content pt-3" id="nav-tabContent">
            <!-- detai tab1 Start -->
            <div class="tab-pane fade show active" id="nav-home" role="tabpanel" aria-labelledby="nav-home-tab">
                <button type="button" class="btn btn-primary m-2" onclick="location.href='/Home/Create'">Đăng ký vào</button>

                <button type="button" class="btn btn-primary m-2" data-bs-toggle="modal" id="qrCodeButton1" data-bs-target="#qrCodeModal">
                    <i class="fas fa-qrcode me-2"></i>Đăng ký ra
                </button>

                <div class="table-responsive mt-3">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.ErrorMessage
                        </div>
                    }
                    else
                    {
                        <table class="table table-bordered">
                            <thead class="table-primary">
                                <tr>
                                    <th>stt</th>
                                    <th>số thẻ</th>
                                    <th>b.số xe</th>
                                    <th>số cont</th>
                                    <th>loại xe</th>
                                    <th>tên xe</th>
                                    <th>cccd</th>
                                    <th>số đt</th>
                                    <th>mục đích</th>
                                    <th>ghi chú</th>
                                    <th>vào lúc</th>
                                    <th>cho vào bởi</th>
                                    <th>Ra lúc</th>
                                    <th>cho Ra bởi</th>
                                    
                                    <th>Có HH</th>
                                    <th>Có cont vào</th>
                                    <th>Có cont ra</th>
                                </tr>
                                
                            </thead>
                            <tbody>
                                @if (Model is List<MACS.Models.HistoryCar> listModel)
                                {
                                    int index = 1;
                                    foreach (var item in listModel)
                                    {
                                        <tr>
                                            <td>@index</td>
                                            <td>@item.CardNo</td>
                                            <td>@item.LicensePlate</td>
                                            <td>@item.TypeCode</td>
                                            <td>@item.VehicleType</td>
                                            <td>@item.DriverName</td>
                                            <td>@item.PersonalId</td>
                                            <td>@item.PhoneNo</td>
                                            <td>@item.Purpose</td>
                                            <td>@item.Remark</td>
                                            <td>@item.GetInDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@item.GetInBy</td>
                                            <td>@item.GetOutDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@item.GetOutBy</td>
                                            <td>
                                                <input class="form-check-input" type="checkbox" @(item.IsCarried ? "checked" : "") disabled />
                                            </td>
                                            <td>
                                                <input class="form-check-input" type="checkbox" @(item.IsCarriedIn ? "checked" : "") disabled>
                                            </td>
                                            <td>
                                                <input class="form-check-input" type="checkbox" @(item.IsCarriedOut ? "checked" : "") disabled>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="12" class="text-center">Không có dữ liệu để hiển thị.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
            <!-- detai tab1 End -->

            <!-- detai tab2 Start -->
            <div class="tab-pane fade" id="nav-profile" role="tabpanel" aria-labelledby="nav-profile-tab">
                <div class="table-responsive mt-3">
                    <p id="message">@ViewBag.Message</p>
                    <table class="table table-bordered">
                        <thead class="table-primary">
                            <tr>
                                <th>Field</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.Result != null)
                            {
                                var result = ViewBag.Result as QrCodeResponse;

                                <tr>
                                    <td>Message</td>
                                    <td>@result.Message</td>
                                </tr>

                                @if (result.Data != null && result.Data.Any())
                                {
                                    foreach (var item in result.Data)
                                    {
                                        <tr>
                                            <td>Data</td>
                                            <td>@item</td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- detai tab2 end -->
        </div>
    </div>
        <!-- Kết quả tải lên -->
        @if (ViewBag.Results != null)
        {
            <div class="custom-alert">
                <h6>Kết quả:</h6>
                <ul>
                    @foreach (var result in (List<string>)ViewBag.Results)
                    {
                        <li>@result</li>
                    }
                </ul>
            </div>
        }
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            alert('@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData["SuccessMessage"]?.ToString() ?? "")');
        </script>
        <div class="custom-alert success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            alert('@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData["ErrorMessage"]?.ToString() ?? "")');
        </script>
        <div class="custom-alert error">
            @TempData["ErrorMessage"]
        </div>
    }


</div>
<!-- body End -->

<!-- Modal QR Code -->
<div class="modal fade" id="qrCodeModal" tabindex="-1" aria-labelledby="qrCodeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="qrCodeModalLabel">Quét QR Code</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div>
                    <video id="camera" autoplay class="w-100 h-auto border border-secondary rounded" ></video>
                    <canvas id="canvas" style="display: none;"></canvas> 
                </div>

                <form id="uploadForm" method="post" enctype="multipart/form-data" asp-action="ScanQR">
                    <input type="file" id="imageInput" name="qrImage" style="display: none;"> 
                    <button type="submit" style="display: none;" id="submitButton">Upload</button> 
                </form>
            </div>

            <div class="modal-footer">
                <button id="switchCamera" class="btn btn-primary mt-3">Đổi Camera</button>
            </div>
        </div>
    </div>
</div>
<!-- Modal QR Code -->

<script>
    //xử lý video
    const video = document.getElementById('camera');
    const canvas = document.getElementById('canvas');
    const captureButton = document.getElementById('captureButton');
    const imageInput = document.getElementById('imageInput');
    const submitButton = document.getElementById('submitButton');
    const switchCameraButton = document.getElementById('switchCamera');
    const qrCodeButton = document.getElementById('qrCodeButton');
    const qrCodeButton1 = document.getElementById('qrCodeButton1');
    const qrCodeModal = document.getElementById('qrCodeModal');
    const message = document.getElementById('message');

    let currentStream; // Lưu trữ stream hiện tại
    let isFrontCamera = false; // Mặc định là camera trước
    let qrDetected = false; // Trạng thái nhận diện QR Code
    let lastQRCode = '';


    // Hàm khởi tạo camera
    async function startCamera() {
        if (currentStream) {
            // Dừng tất cả các track của stream hiện tại
            currentStream.getTracks().forEach(track => track.stop());
        }

        const constraints = {
            video: {
                facingMode: isFrontCamera ? 'user' : 'environment', // Camera trước hoặc sau
                // độ phân giải
                width: { ideal: 1920 }, 
                height: { ideal: 1080 }, 
                frameRate: { ideal: 60 }, 
            },
        };

        try {
            currentStream = await navigator.mediaDevices.getUserMedia(constraints);
            video.srcObject = currentStream;
            // Đợi video sẵn sàng
            video.addEventListener('loadedmetadata', () => {
                video.play();
                scanQRCode(); 
            });
        } catch (err) {
            console.error('Error accessing camera:', err);
            message.innerText = 'Không thể truy cập camera. Vui lòng kiểm tra quyền truy cập.';
        }
    }

    // Hàm quét QR Code
    function scanQRCode() {
        const context = canvas.getContext('2d');

        const scan = () => {
            if (video.videoWidth === 0 || video.videoHeight === 0) {
                requestAnimationFrame(scan);
                return;
            }

            // Vẽ khung hình hiện tại của video lên canvas
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            context.drawImage(video, 0, 0, canvas.width, canvas.height);

            // Lấy dữ liệu hình ảnh từ canvas
            const imageData = context.getImageData(0, 0, canvas.width, canvas.height);

            // Sử dụng thư viện jsQR để quét mã QR
            const code = jsQR(imageData.data, imageData.width, imageData.height);

            if (code) {
                lastQRCode = code.data; // Lưu mã QR đã quét
                qrDetected = true;
                console.log('QR Code detected:', code.data);

                // Đóng modal và chuyển hướng
                bootstrap.Modal.getInstance(document.getElementById('qrCodeModal')).hide();
                location.href = `/Home/Edit/${code.data}`;

                // // Gửi hình ảnh khi mã QR đã được xác định
                // if (qrDetected) {
                //     // Chụp ảnh từ video stream để gửi API
                //     canvas.toBlob(
                //         blob => {
                //             const file = new File([blob], 'capture.png', { type: 'image/png' });

                //             const dataTransfer = new DataTransfer();
                //             dataTransfer.items.add(file);
                //             imageInput.files = dataTransfer.files;

                //             // Submit form tự động
                //             submitButton.click();
                //         },
                //         'image/png',
                //         1.0 // Chất lượng cao nhất
                //     );

                //     // Ngừng quét sau khi phát hiện mã QR
                //     qrDetected = false;
                //     return;
                // }
            } else {
                qrDetected = false;
                message.innerText = 'Không tìm thấy mã QR, vui lòng giữ camera ổn định...';
            }

            // Lặp lại quét nếu chưa tìm thấy mã QR
            requestAnimationFrame(scan);
        };

        scan();
    }

    // Sự kiện nhấn nút chuyển đổi camera
    switchCameraButton.addEventListener('click', () => {
        isFrontCamera = !isFrontCamera;
        startCamera(); 
    });

    // Sự kiện nhấn nút QRCode để khởi động camera
    qrCodeButton.addEventListener('click', () => {
        startCamera(); 
    });
    qrCodeButton1.addEventListener('click', () => {
        startCamera();
    });

    // Tắt camera khi đóng modal
    qrCodeModal.addEventListener('hidden.bs.modal', () => {
        if (currentStream) {
            currentStream.getTracks().forEach(track => track.stop());
        }
    });

    // Xử lý hiển thị container
    document.addEventListener("DOMContentLoaded", function () {
        const containerIn = document.getElementById("containerIn");
        const containerOut = document.getElementById("containerOut");
        const hasContainerIn = document.getElementById("hasContainerIn");
        const hasContainerOut = document.getElementById("hasContainerOut");

        function toggleContainerTable() {
            if (hasContainerIn.checked) {
                containerIn.classList.remove("d-none");
            } else {
                containerIn.classList.add("d-none");
            }
        }
        function toggleContainerTable2() {
            if (hasContainerOut.checked) {
                containerOut.classList.remove("d-none");
            } else {
                containerOut.classList.add("d-none");
            }
        }

        hasContainerIn.addEventListener("change", toggleContainerTable);
        hasContainerOut.addEventListener("change", toggleContainerTable2);
    });
</script>

